type Vec2 = f32[2]

struct Decal {
	Color3 : Color3?,

	ColorMap : string?,

	Transparency : f32?,

	UVOffset : Vec2?,
	UVScale : Vec2?,

	ZIndex : u32?,

	Face : u8(0..5)?
}

struct Texture {
	..Decal,

	OffsetStudsU : f32?,
	OffsetStudsV : f32?,
	StudsPerTileU : f32?,
	StudsPerTileV : f32?,
}

struct Light {
	ClassName : string,

	Brightness : f32?,
	Color : Color3?,
	Shadows : boolean?,
	Range : f32?,

	Angle : f32?,
	Face : u8(0..5)?
}

struct PartProperties {
	Anchored : boolean,

	Color : Color3?,
	Material : u16(256..2311)?,
	Transparency : f16?,
	Reflectance : f16?,
	MaterialVariant : string?,
	CollisionGroup : string?,

	LeftSurface : u8(0..10)?,
	RightSurface : u8(0..10)?,
	FrontSurface : u8(0..10)?,
	BackSurface : u8(0..10)?,
	TopSurface : u8(0..10)?,
	BottomSurface : u8(0..10)?,

	Textures : Texture[]?,

	Lights : Light[]?,

	Decals : Decal[]?,

	Attributes : map{ [string]: unknown },
	Tags : string[]
}

struct Box {
	CFrame : CFrame,
	Size : vector
}

struct Hitbox {
	..Box,

	Shape : u8(0..4)
}

struct PartInstance {
	..Box,
	..PartProperties
}

struct Puppet {
	GUID : string,

	..Box,
	..PartProperties
}

struct DestructionParamsType {
	ID : string,

	CuttingPart : Hitbox,
	
	FilterTagged : string[]?,
	GridSize : f32?,
	CleanupDelay : f32?,
	
	SkipEncapsulatedVoxels : boolean?,

	OnVoxelDestruct : string?,
	UserData : unknown?
}

struct PuppetState {
	GUID : string,
	CFrame : CFrame 
}







event SignalClearQueue {
	From: Server,
	Type: Reliable,
	Call: ManyAsync
}

event SignalReset {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: boolean
}

event SignalResetArea {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: (CFrame, vector)
}




event CreatePuppets {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: PartInstance[]
}

event ReplicatePuppetStates {
	From: Server,
	Type: Unreliable,
	Call: ManyAsync,
	Data: (buffer(14..994), u16)
}

event DestroyPuppet {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: u16
}



event CreateDirtyGroupsFromClient {
	From: Client,
	Type: Reliable,
	Call: ManyAsync,
	Data: map{ [string]: Instance(Part) } -- clients must mark dirty parts that also exist on the server side
}


event CreateDirtyGroupsFromServer {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: map{ [string]: PartInstance }
}



event ReplicateState {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: (
			map{ [string]: PartInstance },
			map{ [string]: PartInstance[] },
			map{ [string]: boolean },

			DestructionParamsType[],
			map{ [string]: u32 },
			map{ [string]: map{ [string]: boolean } },

			map{ [string]: f32 },

			map{ [string]: f32 },
			map{ [string]: f32 },

			PartInstance[]
		)
}

event ReplicateDestruction {
	From: Server,
	Type: Reliable,
	Call: ManyAsync,
	Data: (string, DestructionParamsType, map{ [string]: PartInstance }, map{ [string]: boolean }?)
}


event ClientInitComplete {
	From: Client,
	Type: Reliable,
	Call: SingleAsync
}


event SignalPrintState {
	From: Server,
	Type: Reliable,
	Call: ManyAsync
}